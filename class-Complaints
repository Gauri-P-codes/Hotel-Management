  boolean check(DepartmentDuty dep) { 
   int m=0,per=-1; 
   boolean check=false; 
   int sh=shift(LocalTime.now()); 
   for (Staff k:presents){ 
    if (k.dept.equals(dep) &&k.x>=m && k.sh==sh){ 
              m = k.x; 
              per = presents.indexOf(k); 
           } 
    } 
    if (per >= 0) { 
             Staff j = presents.get(per); 
             j.x += 1; 
             check=true; 
             System.out.println(j.name + " will be helping you shortly.\nThank you."); 
         } 
   return check; 
  } 
