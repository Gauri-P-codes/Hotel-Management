 // to get the date   
  protected LocalDate date() { 
   LocalDate date; 
   System.out.println("Enter The Dates Of Stay  : "); 
   String d=HotelInterfaces.date(1); 
   try { 
     DateTimeFormatter formatter = 
DateTimeFormatter.ofPattern("yyyy-MM-dd"); 
     date = LocalDate.parse(d,formatter); 
   } 
   catch(Exception e) { 
     date = LocalDate.now(); 
    System.out.println("Invalid Input.Please Retry "); 
   } 
   return date; 
    
  } 
  // to display each room 
  int room(Price per) { 
   int room=0; 
   try { 
    switch (per) { 
          case guest_room: 
              for (int i = 0; i < gr.length; i++) { 
                  if (!gr[i]) { // Find the first available room 
                      gr[i] = true; 
                      room =(1+i); 
                      break; 
                  } 
              } 
              break; 
          case executive_suite: 
              for (int i = 0; i < es.length; i++) { 
                  if (!es[i]) { 
                      es[i] = true; 
                      room =(81+i); 
                      break; 
                  } 
              } 
              break; 
          case soho_suite: 
              for (int i = 0; i < ss.length; i++) { 
                  if (!ss[i]) { 
                      ss[i] = true; 
                      room =(81+50+i); 
                      break; 
                  } 
              } 
              break; 
          case presidential_suite: 
              for (int i = 0; i < ps.length; i++) { 
                  if (!ps[i]) { 
                      ps[i] = true; 
                      room =(81+100+i); 
                      break; 
                  } 
              } 
              break; 
      } 
   }catch(Exception e) { 
    room=-1; 
   } 
      return room; 
  } 
  void check() { 
   if(!future.isEmpty()) { 
    for(Guest g:future) { 
     if(check(g.cindate,g.day)) { 
      roomrefill(g.per,g.room); 
     } 
    } 
   } 
  } 
  //to refill the rooms 
  protected void roomrefill(Price per,int room) { 
   int reroom=room; 
   switch(per) { 
   case guest_room: 
    if(gr[(reroom-1)]==true) { 
     gr[(reroom-1)]=false; 
    } 
    break; 
   case executive_suite: 
    if(es[(reroom-1-80)]==true) { 
     es[(reroom-1-80)]=false; 
    } 
    break; 
   case soho_suite: 
    if(ss[(reroom-1-80-50)]==true) { 
     ss[(reroom-1-80-50)]=false; 
    } 
    break; 
    case presidential_suite: 
     if(ps[(reroom-1-80-50-50)]==true) { 
      ps[(reroom-1-80-50-50)]=false; 
     } 
     break; 
   } 
  } 
  boolean check(LocalDate n,int day) { 
    LocalDate nc=LocalDate.now(); 
    if(nc.isBefore(n.plusDays(day))||nc.equals(n.plusDays(day))) { 
     return false; 
    }else { 
     return true; 
    } 
  } 
