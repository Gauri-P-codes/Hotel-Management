  // to update info of the present guests 
  @Override 
  public void update() { 
   // TODO Auto-generated method stub 
   check(); 
   System.out.print("Enter your name :"); 
         String check_name=sc.next(); 
         System.out.print("Enter Authentication ID Provided During booking(Aadhar 
card/Passport/Driving License / PAN Card) :"); 
         String check_id=sc.next(); 
         System.out.print("Please enter the number of rooms you wish to update."); 
         int num= sc.nextInt(); 
         boolean check=false, avail=false; 
         for(int j=0;j<num;j++) 
         { 
             System.out.println("Kindly specify the type of room you wish to update."); 
             String room_type_updation =sc.next(); 
             System.out.println("Enter room number:"); 
             int room_num=sc.nextInt(); 
             for(Guest g:present) 
             { 
                 if(g.typeRoom.equals(room_type_updation) && g.room!=-1) 
                 { 
                     avail=false; 
                 } 
                 else { 
                     avail=true; 
                 } 
             } 
             if(avail) 
             { 
                 for(Guest g:present) 
                 { 
                     if(g.name.equals(check_name) && g.id.equals(check_id)&& 
g.room==room_num ) 
                     { 
                         g.typeRoom=room_type_updation; 
                         g.per=Price.valueOf(room_type_updation); 
                         g.room=room(g.per); 
                         roomrefill(Price.valueOf(g.typeRoom),g.room); 
                         check=true; 
                         System.out.println("Successfully Updated!"); 
                     } 
                 } 
                 if(!check) 
                 { 
                     System.out.println("Invalid Details"); 
                 } 
             } 
             else { 
                 System.out.println("Sorry, Room not Available. "); 
             } 
         } 
  } 
