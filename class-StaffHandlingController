public class StaffHandlingController extends StaffHandling{ 
     void controller(){ 
      while(true) { 
          System.out.println("Menu:"); 
          System.out.println("1.Accept details of staff."); 
          System.out.println("2.Display details of staff."); 
          System.out.println("3.Update details of staff."); 
          System.out.println("4.Search staff by various means."); 
          System.out.println("5.Deletion of staff members."); 
          System.out.println("6.Go back to Main Menu."); 
          System.out.println("7.Exit."); 
          System.out.print("Enter choice :"); 
          int choice=sc.nextInt(); 
          switch(choice){ 
           case 1: 
            accept(); 
                  break; 
              case 2: 
                  display(); 
                  break; 
              case 3: 
                  update(); 
                  break; 
              case 4: 
                 search(); 
                 break; 
              case 5: 
                 out(); 
                  break; 
              case 6: 
               return; 
              case 7: 
               System.out.println("Thank you for choosing us! Have a great day 
ahead!"); 
                  System.exit(0); 
                  break; 
              } 
     } 
 } 
} 
