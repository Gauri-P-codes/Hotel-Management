 StaffHandling(){ 
  uid.put(DepartmentDuty.chef, 0); 
  uid.put(DepartmentDuty.house_keeping, 0); 
  uid.put(DepartmentDuty.maintenance, 0); 
  uid.put(DepartmentDuty.waiter, 0); 
