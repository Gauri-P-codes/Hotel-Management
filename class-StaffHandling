  uid.put(DepartmentDuty.security, 0); 
  uid.put(DepartmentDuty.manager,0); 
 } 
 int shift(LocalTime time) { 
  if((time.equals(LocalTime.of(7, 0)))||(time.isBefore(LocalTime.of(15, 
0))&&time.isAfter(LocalTime.of(7, 0)))){ 
   return 1; 
  } 
  else if((time.equals(LocalTime.of(15, 0)))||time.isBefore(LocalTime.of(23, 
0))&&time.isAfter(LocalTime.of(15, 0))) { 
   return 2; 
  } 
  else if((time.equals(LocalTime.of(23, 0)))||time.isBefore(LocalTime.of(7, 
0))&&time.isAfter(LocalTime.of(23, 0))){ 
   return 3; 
  } 
  else { 
   return -1; 
  } 
 } 
 private String uid1(String dept) { 
  try { 
  DepartmentDuty d=DepartmentDuty.valueOf(dept); 
  uid.put(d,uid.get(d)+1); 
  String cast=d.toString().charAt(0)+uid.get(d).toString(); 
  return cast.toUpperCase(); 
  } 
  catch(Exception e){ 
   System.out.println("Invalid Input."); 
   return null; 
  } 
 } 
